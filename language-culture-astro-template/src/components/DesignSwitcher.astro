---
import { designOptions } from '../data/designOptions';

const { currentSlug = '' } = Astro.props;
const currentDesign = designOptions.find((design) => design.slug === currentSlug);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="design-switcher-panel" aria-label="Switch website design">
  <div>
    <p class="eyebrow" data-language-1="Switch design" data-language-2="Switch design — L2">Switch design</p>
    <h2 data-language-1="Choose another visual style" data-language-2="Language 2: Choose another visual style">Choose another visual style</h2>
    <p data-language-1="The content, posts, and calendar stay the same. This control only changes the visual design preview." data-language-2="Language 2 placeholder: the content, posts, and calendar stay the same. Only the visual design changes.">
      The content, posts, and calendar stay the same. This control only changes the visual design preview.
    </p>
  </div>

  <div class="design-switcher-control">
    <label for="design-select" data-language-1="Design style" data-language-2="Design style — L2">Design style</label>

    <select id="design-select" data-design-select>
      {designOptions.map((design) => (
        <option value={`${base}designs/${design.slug}/`} selected={design.slug === currentSlug}>
          {design.name}
        </option>
      ))}
    </select>

    <button type="button" class="switch-design-button" data-switch-design-button>
      Switch to selected design
    </button>

    <a class="all-designs-link" href={`${base}designs/`} data-language-1="Compare all designs" data-language-2="Compare all designs — L2">
      Compare all designs
    </a>
  </div>
</section>

{currentDesign && <p class="current-design-note">Current preview: <strong>{currentDesign.name}</strong></p>}

<script is:inline>
  const designSelect = document.querySelector('[data-design-select]');
  const switchDesignButton = document.querySelector('[data-switch-design-button]');

  if (designSelect && switchDesignButton) {
    switchDesignButton.addEventListener('click', () => {
      window.location.href = designSelect.value;
    });
  }
</script>