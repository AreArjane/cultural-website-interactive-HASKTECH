---
import { events } from '../data/events';

const eventsJson = JSON.stringify(events);
---

<section class="calendar-shell" id="events" data-events={eventsJson}>
  <div class="section-heading">
    <p class="eyebrow" data-language-1="Interactive calendar" data-language-2="Interactive calendar — Language 2">
      Interactive calendar
    </p>
    <h2 data-language-1="Track learning and culture events" data-language-2="Language 2: Track learning and culture events">
      Track learning and culture events
    </h2>
    <p
      data-language-1="Click a highlighted day to see the event. This can later connect to a CMS or database."
      data-language-2="Language 2 placeholder: click a highlighted day to see the event. This can later connect to a CMS or database."
    >
      Click a highlighted day to see the event. This can later connect to a CMS or database.
    </p>
  </div>

  <div class="calendar-card">
    <div class="calendar-top">
      <button type="button" class="calendar-nav" data-calendar-prev aria-label="Previous month">‹</button>
      <h3 data-calendar-title>Month Year</h3>
      <button type="button" class="calendar-nav" data-calendar-next aria-label="Next month">›</button>
    </div>

    <div class="calendar-grid calendar-weekdays" aria-hidden="true">
      <span>Mon</span>
      <span>Tue</span>
      <span>Wed</span>
      <span>Thu</span>
      <span>Fri</span>
      <span>Sat</span>
      <span>Sun</span>
    </div>

    <div class="calendar-grid calendar-days" data-calendar-days></div>

    <aside class="event-panel" data-event-panel>
      <p class="eyebrow" data-language-1="Selected event" data-language-2="Selected event — Language 2">
        Selected event
      </p>
      <h4 data-event-title data-language-1="Choose a highlighted date" data-language-2="Language 2: Choose a highlighted date">
        Choose a highlighted date
      </h4>
      <p data-event-meta>—</p>
      <p
        data-event-description
        data-language-1="Event details will appear here."
        data-language-2="Language 2 placeholder: event details will appear here."
      >
        Event details will appear here.
      </p>
    </aside>
  </div>
</section>

<script is:inline>
  const calendarShell = document.querySelector('.calendar-shell');
  const calendarEvents = JSON.parse(calendarShell.dataset.events);
  const calendarDays = document.querySelector('[data-calendar-days]');
  const calendarTitle = document.querySelector('[data-calendar-title]');
  const prevButton = document.querySelector('[data-calendar-prev]');
  const nextButton = document.querySelector('[data-calendar-next]');
  const eventTitle = document.querySelector('[data-event-title]');
  const eventMeta = document.querySelector('[data-event-meta]');
  const eventDescription = document.querySelector('[data-event-description]');

  const monthNames = [
    'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'
  ];

  let activeDate = new Date('2026-07-01T12:00:00');

  function getCurrentLanguage() {
    return document.documentElement.dataset.language || 'language1';
  }

  function eventForDate(dateString) {
    return calendarEvents.find((event) => event.date === dateString);
  }

  function formatDate(year, month, day) {
    return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  }

  function updateEventPanel(event) {
    const language = getCurrentLanguage();

    if (!event) {
      eventTitle.dataset.language1 = 'Choose a highlighted date';
      eventTitle.dataset.language2 = 'Language 2: Choose a highlighted date';
      eventTitle.textContent = language === 'language2'
        ? eventTitle.dataset.language2
        : eventTitle.dataset.language1;

      eventMeta.textContent = '—';

      eventDescription.dataset.language1 = 'Event details will appear here.';
      eventDescription.dataset.language2 = 'Language 2 placeholder: event details will appear here.';
      eventDescription.textContent = language === 'language2'
        ? eventDescription.dataset.language2
        : eventDescription.dataset.language1;
      return;
    }

    eventTitle.dataset.language1 = event.title.language1;
    eventTitle.dataset.language2 = event.title.language2;
    eventDescription.dataset.language1 = event.description.language1;
    eventDescription.dataset.language2 = event.description.language2;

    eventTitle.textContent = language === 'language2' ? event.title.language2 : event.title.language1;
    eventMeta.textContent = `${event.date} · ${event.time} · ${event.category}`;
    eventDescription.textContent = language === 'language2'
      ? event.description.language2
      : event.description.language1;
  }

  function renderCalendar() {
    const year = activeDate.getFullYear();
    const month = activeDate.getMonth();
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const startOffset = (firstDay.getDay() + 6) % 7;

    calendarTitle.textContent = `${monthNames[month]} ${year}`;
    calendarDays.innerHTML = '';

    for (let i = 0; i < startOffset; i++) {
      const emptyCell = document.createElement('span');
      emptyCell.className = 'calendar-day empty';
      calendarDays.appendChild(emptyCell);
    }

    for (let day = 1; day <= lastDay.getDate(); day++) {
      const dateString = formatDate(year, month, day);
      const event = eventForDate(dateString);
      const button = document.createElement('button');

      button.type = 'button';
      button.className = event ? 'calendar-day has-event' : 'calendar-day';
      button.textContent = String(day);
      button.setAttribute('aria-label', event ? `Event on ${dateString}` : dateString);

      if (event) {
        const dot = document.createElement('span');
        dot.className = 'event-dot';
        button.appendChild(dot);
        button.addEventListener('click', () => updateEventPanel(event));
      }

      calendarDays.appendChild(button);
    }
  }

  prevButton.addEventListener('click', () => {
    activeDate = new Date(activeDate.getFullYear(), activeDate.getMonth() - 1, 1);
    renderCalendar();
    updateEventPanel(null);
  });

  nextButton.addEventListener('click', () => {
    activeDate = new Date(activeDate.getFullYear(), activeDate.getMonth() + 1, 1);
    renderCalendar();
    updateEventPanel(null);
  });

  document.addEventListener('click', (event) => {
    if (event.target.matches('[data-language-button]')) {
      const selectedEventTitle = eventTitle.dataset.language1;
      const selectedEventDescription = eventDescription.dataset.language1;

      if (selectedEventTitle && selectedEventDescription) {
        const language = getCurrentLanguage();
        eventTitle.textContent = language === 'language2'
          ? eventTitle.dataset.language2
          : eventTitle.dataset.language1;
        eventDescription.textContent = language === 'language2'
          ? eventDescription.dataset.language2
          : eventDescription.dataset.language1;
      }
    }
  });

  renderCalendar();
</script>
