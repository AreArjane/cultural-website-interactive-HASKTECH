---
const { post } = Astro.props;
---

<article class="post-card">
  <p class="eyebrow">{post.type} · {post.date}</p>
  <h3
    data-language-1={post.title.language1}
    data-language-2={post.title.language2}
  >
    {post.title.language1}
  </h3>
  <p
    data-language-1={post.summary.language1}
    data-language-2={post.summary.language2}
  >
    {post.summary.language1}
  </p>
  <a
    href="#"
    class="text-link"
    data-language-1="Read more"
    data-language-2="Zêdetir bixwîne"
  >
    Read more
  </a>
</article>
