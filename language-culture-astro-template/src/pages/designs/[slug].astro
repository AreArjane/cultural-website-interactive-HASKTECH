---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Calendar from '../../components/Calendar.astro';
import PostCard from '../../components/PostCard.astro';
import DesignSwitcher from '../../components/DesignSwitcher.astro';
import { posts } from '../../data/posts';
import { designOptions } from '../../data/designOptions';
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

export function getStaticPaths() {
  return designOptions.map((design) => ({ params: { slug: design.slug }, props: { design } }));
}

const { design } = Astro.props;
---

<BaseLayout title={`${design.name} — Language & Culture`} bodyClass={`design-template ${design.className}`}>
  <Header />
  <main>
    <section class="design-preview-hero">
      <div>
        <p class="eyebrow" data-language-1="Design preview" data-language-2="Design preview — L2">Design preview</p>
        <h1>{design.name}</h1>
        <p data-language-1="This page uses the same organisation content as the other design previews. Only the visual style is different." data-language-2="Language 2 placeholder: this page uses the same content as the other previews, but with another visual style.">
          This page uses the same organisation content as the other design previews. Only the visual style is different.
        </p>
        <div class="hero-actions">
          <a class="primary-button" href="#events" data-language-1="View calendar" data-language-2="View calendar — L2">View calendar</a>
          <a class="secondary-button"  href={`${base}designs/`} data-language-1="Back to designs" data-language-2="Back to designs — L2">Back to designs</a>
        </div>
      </div>
      <aside class="design-info-card">
        <p class="eyebrow" data-language-1="Selected style" data-language-2="Selected style — L2">Selected style</p>
        <strong>{design.name}</strong>
        <p>{design.description}</p>
      </aside>
    </section>

    <DesignSwitcher currentSlug={design.slug} />

    <section class="design-content-grid">
      <article><span>01</span><h2 data-language-1="Language learning" data-language-2="Language 2: Language learning">Language learning</h2><p data-language-1="Course pages, vocabulary resources, pronunciation exercises, and learner groups can be added later." data-language-2="Language 2 placeholder: course pages, vocabulary resources, pronunciation exercises, and learner groups can be added later.">Course pages, vocabulary resources, pronunciation exercises, and learner groups can be added later.</p></article>
      <article><span>02</span><h2 data-language-1="Culture content" data-language-2="Language 2: Culture content">Culture content</h2><p data-language-1="Articles, public posts, culture notes, and community updates can be published on the homepage." data-language-2="Language 2 placeholder: articles, public posts, culture notes, and community updates can be published on the homepage.">Articles, public posts, culture notes, and community updates can be published on the homepage.</p></article>
      <article><span>03</span><h2 data-language-1="Events" data-language-2="Language 2: Events">Events</h2><p data-language-1="The calendar can later connect to real event registration, reminders, and admin management." data-language-2="Language 2 placeholder: the calendar can later connect to real event registration, reminders, and admin management.">The calendar can later connect to real event registration, reminders, and admin management.</p></article>
    </section>

    <section class="posts-section" id="posts">
      <div class="section-heading">
        <p class="eyebrow" data-language-1="Shared posts" data-language-2="Shared posts — L2">Shared posts</p>
        <h2 data-language-1="Same posts, different design" data-language-2="Language 2: Same posts, different design">Same posts, different design</h2>
        <p data-language-1="These posts come from the same data file used by all design routes." data-language-2="Language 2 placeholder: these posts come from the same data file used by all design routes.">These posts come from the same data file used by all design routes.</p>
      </div>
      <div class="post-grid">{posts.map((post) => <PostCard post={post} />)}</div>
    </section>

    <Calendar />
  </main>
</BaseLayout>
